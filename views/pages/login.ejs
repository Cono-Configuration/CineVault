<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: typeof title !== 'undefined' ? title : 'Log in — CineVault' }) %>
</head>
<body>
  <div class="sprocket-rail sprocket-rail--left" aria-hidden="true"></div>
  <div class="sprocket-rail sprocket-rail--right" aria-hidden="true"></div>

  <div class="page">
    <%- include('../partials/header') %>

    <main class="section-main section-main--narrow">
      <div class="page-heading">
        <h1>Log in</h1>
      </div>

      <% var errs = typeof errors !== 'undefined' ? errors : {}; %>
      <% var fd = typeof formData !== 'undefined' ? formData : {}; %>

      <% if (errs.general) { %><p class="form-error"><%= errs.general %></p><% } %>

      <form action="/login" method="POST" class="movie-form">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="<%= fd.email || '' %>" required>

        <label for="password">Password</label>
        <input type="password" id="password" name="password" required>

        <div class="form-actions">
          <button type="submit" class="btn btn--primary">Log in</button>
        </div>
      </form>

      <p class="auth-switch">No vault yet? <a href="/signup">Sign up</a></p>
    </main>

    <%- include('../partials/footer') %>
  </div>
</body>
</html>
